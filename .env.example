# MediVita – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<app>
# Get this from: https://cloud.mongodb.com/ → Database → Connect
MONGO_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>"
MONGO_DB="hospital_management"

